# Admin panel password — set this to a strong secret in .env.local
ADMIN_PASSWORD=buraya-guclu-bir-sifre-yazin

# ── PDF catalog storage ───────────────────────────────────────────────
# Local dev: leave the two lines below as-is (unset) → PDFs are saved to
# the filesystem (public/kataloglar) and indexed in data/katalog-manifest.json.
#
# On Vercel: create a Blob store (Storage tab) — it auto-injects
# BLOB_READ_WRITE_TOKEN — then set NEXT_PUBLIC_USE_BLOB=1 in project env vars.
# Catalogs (and their JSON index) are then stored durably in Vercel Blob.
NEXT_PUBLIC_USE_BLOB=
# BLOB_READ_WRITE_TOKEN=   # provided automatically by the Vercel Blob integration
