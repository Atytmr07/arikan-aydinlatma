# Admin panel password — set this to a strong secret in .env.local
ADMIN_PASSWORD=buraya-guclu-bir-sifre-yazin

# ── PDF catalog storage ───────────────────────────────────────────────
# Local dev: leave everything below unset → PDFs are saved to the
# filesystem (public/kataloglar) and indexed in data/katalog-manifest.json.
#
# Production: create a Firebase project on the Blaze plan, enable Storage,
# then create a service-account key (Project settings → Service accounts →
# Generate new private key) and fill in the four values below.
# Also set NEXT_PUBLIC_USE_FIREBASE=1 so the admin panel uploads directly
# to Firebase Storage via signed URLs.
#
# The bucket needs a one-time CORS setup for browser uploads — see
# scripts/cors.json and the README.
NEXT_PUBLIC_USE_FIREBASE=
# FIREBASE_PROJECT_ID=arikan-aydinlatma
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@arikan-aydinlatma.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_STORAGE_BUCKET=arikan-aydinlatma.firebasestorage.app
